default_platform(:android)

platform :android do

  desc "Run tests"
  lane :test do
    gradle(task: "test")
  end

  desc "Build TV debug APK"
  lane :build_debug do
    gradle(task: ":tv:assembleDebug")
  end

  desc "Build TV release AAB for Play"
  lane :build_release do
    gradle(task: ":tv:bundleRelease")
  end

  desc "Build TV release APK for GitHub distribution"
  lane :build_full_release do
    gradle(task: ":tv:assembleRelease")
  end

  desc "Deploy TV to internal testing track"
  lane :internal do
    gradle(task: ":tv:bundleRelease")
    upload_to_play_store(
      track: "internal",
      aab: "tv/build/outputs/bundle/release/tv-release.aab",
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
    )
  end

  desc "Deploy TV to closed testing track"
  lane :beta do
    gradle(task: ":tv:bundleRelease")
    upload_to_play_store(
      track: "beta",
      aab: "tv/build/outputs/bundle/release/tv-release.aab",
      json_key: "fastlane/play-store-key.json",
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
    )
  end

  desc "Deploy TV to production"
  lane :production do
    gradle(task: ":tv:bundleRelease")
    upload_to_play_store(
      track: "production",
      aab: "tv/build/outputs/bundle/release/tv-release.aab",
      json_key: "fastlane/play-store-key.json",
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      release_status: "draft"
    )
  end

  desc "Increment TV version code"
  lane :bump_version do |options|
    version_name = options[:version] || "1.0"
    # Read current versionCode from tv/build.gradle.kts
    build_gradle = File.read("../tv/build.gradle.kts")
    current_code = build_gradle.match(/versionCode = (\d+)/)[1].to_i
    new_code = current_code + 1

    # Update versionCode
    new_content = build_gradle.gsub(
      /versionCode = \d+/,
      "versionCode = #{new_code}"
    )
    # Update versionName if provided
    new_content = new_content.gsub(
      /versionName = ".*"/,
      "versionName = \"#{version_name}\""
    )
    File.write("../tv/build.gradle.kts", new_content)

    UI.success("✅ TV bumped to versionCode=#{new_code}, versionName=#{version_name}")
  end
end
